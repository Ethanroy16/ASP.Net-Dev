@page
@model MyProject_L00181476.Pages.Admin.Brands.DeleteModel
@{
}
<form method="post">
    <input type="hidden" asp-for="Brand.Id" />
    <div class="border p-3 mt-4">
        <div class="row pb-2">
            <h2 class="text-primary pl-3">Delete Brand</h2>
        </div>

        <div class="mb-3">
            <label>Brand</label>
            <div class="form-control-plaintext">@Model.Brand?.BrandName</div>
        </div>

        <div class="mb-3">
            <label>Country</label>
            <div class="form-control-plaintext">@Model.Brand?.Country</div>
        </div>

        <div class="mb-3">
            <label>Founded Year</label>
            <div class="form-control-plaintext">@Model.Brand?.FoundedYear</div>
        </div>

        <div class="mb-3">
            <p class="text-danger">Are you sure you want to delete this brand?</p>
        </div>

        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-page="Brands" class="btn btn-secondary">Back to Brands</a>
    </div>
</form>
@section Scripts {
    @{
        <partial name="_ValidationScriptsPartial" />
    }
}