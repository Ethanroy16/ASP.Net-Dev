@page "[SearchString]"
@model MyProject_L00181476.Pages.Customer.Home.IndexModel
@{
}

<div class="row container pb-3 backgroundWhite">
    <p>
        <form class="d-flex" class="col-3">
            <input type="text" placeholder="Enter Brand/Product Name" class="form-control me-sm-2" asp-for="SearchString" />
            <input type="submit" value="Search" class="btn btn-outline" class="form-control align-content-end" />
            <a asp-route-GolfBalls="" asp-route-SearchString="" class="btn btn-outline-secondary">Clear</a>
        </form>
    </p>
    </br></br></br>

    @foreach (var brand in Model.listOfBrands)
    {
        <div class="col-12">
            <h2 class="text-success pl-1"><b>@brand.BrandName</b></h2>
            <div class="row my-3">
                @foreach (var golfBall in Model.listOfGolfBalls.Where(b => b.BrandId == brand.Id))
                {
                    <div class="col-lg-4 col-md-6 pb-4 filter">
                        <div class="card bg-white rounded shadow-sm" style="border:1px solid #222">
                            <div class="card-body pb-1 row">
                                <div class="col-8 h5">@golfBall.Name</div>
                                <div class="col-4 text-end">
                                    <span class="text-info h4">@golfBall.Price</span>
                                </div>
                            </div>

                            <img class="card-img-top img-fluid d-block mx-auto mb-3" src="@golfBall.ImageUrl" alt="golf ball image">

                            <div class="card-body p-1 px-3 row">
                                <div class="col-6">
                                    <span class="badge p-2 border w-100 text-dark bg-warning ">@golfBall.Brand?.BrandName</span>
                                </div>
                                <div class="col-6 border-0">
                                    <span class="badge p-2 border w-100 bg-info ">@golfBall.Name</span>
                                </div>

                                <div class="col-12 pt-2" style="font-size:13px; text-align:justify">
                                    <p>@golfBall.Description</p>
                                </div>

                                <div class="col-12 p-1">
                                    <a asp-page="Details" asp-route-id="@golfBall.Id" class="btn btn-dark form-control btn-sm p-2" style="height:40px">
                                        View Details
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    }
</div>
