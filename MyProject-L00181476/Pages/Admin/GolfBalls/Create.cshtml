@page
@model MyProject_L00181476.Pages.Admin.GolfBalls.CreateModel
@{
}
<form method="post" enctype="multipart/form-data">
    <div class="border p-3 mt-4">
        <div class="row pb-2">
            <h2 class="text-primary pl-3">Add New Golf Ball</h2>
        </div>

        <div class="mb-3">
            <label asp-for="GolfBall.Name"></label>
            <input asp-for="GolfBall.Name" class="form-control" />
            <span asp-validation-for="GolfBall.Name" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="GolfBall.BrandId"></label>
            <select asp-for="GolfBall.BrandId" asp-items="Model.BrandsList" class="form-select">
                <option value="">-- Select Brand --</option>
            </select>
            <span asp-validation-for="GolfBall.BrandId" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="GolfBall.Price"></label>
            <input asp-for="GolfBall.Price" type="number" step="0.01" class="form-control" />
            <span asp-validation-for="GolfBall.Price" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="@Model.GolfBall.Description"></label>
            <input asp-for="@Model.GolfBall.Description" class="form-control" />
            <span asp-validation-for="@Model.GolfBall.Description" class="text-danger"></span>
        </div>

            <div class="mb-3">
                <label asp-for="@Model.GolfBall.ImageUrl">FileUpload</label>
                <input type="file" name="files" id="uploadBox" class="form-control" />
            </div>


        <button type="submit" class="btn btn-primary">Create</button>
        <a asp-page="Index" class="btn btn-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
