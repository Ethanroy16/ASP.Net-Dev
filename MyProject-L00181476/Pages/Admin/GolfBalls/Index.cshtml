@page
@model MyProject_L00181476.Pages.Admin.GolfBalls.IndexModel
@{
}

<div class="container p-3">
    <div class="row pt-4">
        <div class="col-6">
            <h3 class="text-primary">Golf Balls</h3>
        </div>
        <div class="col-6">
            <a asp-page="Create" class="btn btn-primary">
                Add New Golf Ball
            </a>
        </div>
    </div>
</div>

<br />
<br />
<br />

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>Golf Balls</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var obj in Model.GolfBall)
        {
            <tr>
                <td width="50%">@obj.Name</td>
                <td width="50%">@obj.BrandId</td>
                <td width="50%">@obj.Price</td>
                <td width="50%">@obj.Description</td>
                <td>
                    <a asp-page="Edit" asp-route-id="@obj.Id" class="btn btn-primary mx-2">Edit</a>
                </td>
                <td>
                    <a asp-page="Delete" asp-route-id="@obj.Id" class="btn btn-danger mx-2">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>